# ─────────────────────────────────────────────
#  AI-SPM  ·  Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# ── Gateway (Node.js) ──────────────────────
GATEWAY_PORT=3000
GATEWAY_SECRET=change_me_in_production

# ── Risk Engine (Python) ───────────────────
RISK_ENGINE_PORT=8000
RISK_ENGINE_URL=http://risk-engine:8000

# ── Dashboard (Next.js) ────────────────────
DASHBOARD_PORT=3001
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3000

# ── AI Providers ───────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Databases ──────────────────────────────
DATABASE_URL=postgresql://aispm:aispm@postgres:5432/aispm
REDIS_URL=redis://redis:6379

# ── Kafka ──────────────────────────────────
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=aispm-gateway

# ── Elasticsearch ──────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200

# ── Auth ───────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# ── Logging ────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
