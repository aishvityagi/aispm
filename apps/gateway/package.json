    "alert:consumer:prod": "node dist/consumers/alertConsumer.js"
  },
  "dependencies": {
    "@aispm/policy-core": "*",
    "@aispm/shared-types": "*",
    "@elastic/elasticsearch": "^8.19.1",
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^7.2.4",
    "@fastify/rate-limit": "^8.1.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.0.0",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "node-fetch": "^2.7.0",
    "pg": "^8.11.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.13",
    "@types/pg": "^8.10.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.0",
    "jest": "^30.3.0",
    "pino-pretty": "^10.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
