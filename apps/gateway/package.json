{
  "name": "@aispm/gateway",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "test": "jest --forceExit",
    "test:watch": "jest --watch --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
